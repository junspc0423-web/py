def exam1(a,b,c):
  k=(a+b+c)/3
  if 0<=a<=100 and 0<=b<=100 and 0<=c<=100 and a%2==0 and b%2==0 and c%2==0 :
    if 90<=k<=100 :
      return "A"
    elif 80<=k<90 :
      return "B"
    elif 70<=k<80 :
      return "C"
    elif 60<=k<70 :
      return "D"
    elif k<60 :
      return "F"
  else :
      return "Invalid value"
